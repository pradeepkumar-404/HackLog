{
  "name": "hacklog",
  "version": "1.0.0",
  "description": "Bug Bounty Research Tracker - A Notion-style notes and daily research tracker for bug bounty hunters",
  "homepage": "https://github.com/pradeepkumar-404/HackLog",
  "author": "HackLog Team",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5000/api/health && electron .\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:clean && npm run build:frontend && npm run build:backend && npm run build:electron",
    "build:clean": "rm -rf frontend/dist backend/node_modules release",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm install --omit=dev",
    "build:electron": "electron-builder",
    "build:arch": "npm run build && electron-builder --linux pacman --x64",
    "build:deb": "npm run build && electron-builder --linux deb --x64",
    "build:appimage": "npm run build && electron-builder --linux AppImage --x64",
    "build:linux": "npm run build && electron-builder --linux pacman deb AppImage --x64",
    "postinstall": "cd backend && npm install && cd ../frontend && npm install",
    "kill-port": "fuser -k 5000/tcp 2>/dev/null || true"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hacklog.app",
    "productName": "HackLog",
    "copyright": "Copyright © 2024 HackLog",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "!**/node_modules",
      "!**/node_modules/**",
      "!**/.git",
      "!**/.gitignore",
      "!**/*.map",
      "!**/test",
      "!**/tests",
      "!**/__tests__",
      "!**/coverage",
      "!**/*.md",
      "!**/.env*",
      "!**/tsconfig.json",
      "!**/package-lock.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!node_modules/**"]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/sqlite3/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "linux": {
      "target": [
        {
          "target": "pacman",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Development",
      "icon": "build/icons",
      "maintainer": "HackLog Team <support@hacklog.app>",
      "description": "Bug Bounty Research Tracker - Notion-style notes for bug bounty hunters. Organize targets, log recon, and track vulnerabilities.",
      "synopsis": "Bug Bounty Research Tracker",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "desktop": {
        "entry": {
          "Name": "HackLog",
          "Comment": "Bug Bounty Research Tracker",
          "Icon": "hacklog",
          "Type": "Application",
          "Categories": "Development;Security;",
          "Keywords": "bugbounty;hacking;security;recon;pentest;",
          "StartupWMClass": "HackLog"
        }
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libsecret-1-0",
        "libasound2"
      ],
      "artifactName": "${productName}-${version}-${arch}.deb"
    },
    "pacman": {
      "depends": [
        "glibc",
        "gcc-libs",
        "nss",
        "libx11",
        "libxss",
        "libxtst",
        "libxkbfile",
        "libsecret",
        "alsa-lib"
      ]
    },
    "npmRebuild": false,
    "publish": null,
    "forceCodeSigning": false
  }
}
