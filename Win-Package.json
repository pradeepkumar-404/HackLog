{
  "name": "hacklog",
  "version": "1.0.0",
  "description": "Bug Bounty Research Tracker - A Notion-style notes and daily research tracker for bug bounty hunters",
  "homepage": "https://github.com/pradeepkumar-404/HackLog",
  "author": "HackLog Team",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5000/api/health && electron .\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:clean && npm run build:frontend && npm run build:backend",
    "build:clean": "rimraf frontend/dist backend/node_modules release",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm install --omit=dev",
    "build:electron": "electron-builder",
    "build:win": "npm run build && electron-builder --win --x64",
    "postinstall": "cd backend && npm install && cd ../frontend && npm install",
    "kill-port": "fuser -k 5000/tcp 2>/dev/null || true"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.1.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hacklog.app",
    "productName": "HackLog",
    "copyright": "Copyright © 2024 HackLog",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "!**/node_modules",
      "!**/.git",
      "!**/*.map",
      "!**/test",
      "!**/tests",
      "!**/__tests__",
      "!**/coverage",
      "!**/*.md",
      "!**/.env*",
      "!**/tsconfig.json",
      "!**/package-lock.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/sqlite3/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HackLog"
    },
    "npmRebuild": false,
    "publish": null,
    "forceCodeSigning": false
  }
}
